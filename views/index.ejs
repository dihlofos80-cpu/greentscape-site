<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title><%= content.siteTitle %> — озеленение и ландшафтный дизайн</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Профессиональное озеленение и ландшафтный дизайн: от проекта до ухода за участком. Ижевск и Удмуртская республика.">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="stylesheet" href="/styles-new.css?v=20">
  <% if (content.heroImage) { %>
  <link rel="preload" as="image" href="<%= content.heroImage %>">
  <% } %>
</head>
<body>

<header <% if (content.heroImage) { %>class="transparent"<% } %> id="mainHeader" <% if (content.headerBg) { %>data-header-bg="<%= content.headerBg %>" data-header-bg-scrolled="<%= content.headerBgScrolled || content.headerBg %>" data-title-color="<%= content.titleColor || '#ffffff' %>" data-title-color-scrolled="<%= content.titleColorScrolled || '#222222' %>" style="background:<%= content.headerBg %>;"<% } %>>
  <div class="container">
    <div class="header-inner">
      
      <div class="logo"><img src="<%= content.logoPath || '/images/logo.png' %>" alt="<%= content.siteTitle || 'Логотип сайта' %>" style="height: <%= content.logoHeight || '50px' %>; opacity: 0.6;"/></div>

      <div class="site-title" style="color:<%= content.titleColor || "#fff" %>;text-shadow:1px 1px 2px rgba(0,0,0,0.5);"><%= content.siteTitle %></div>
      <div class="header-contacts">
        <a href="tel:+<%= content.phone.replace(/[^0-9]/g, '') %>">
          <span class="label">Телефон:</span>
          <span><%= content.phone %></span>
        </a>
        <a href="mailto:<%= content.email %>">
          <span class="label">Почта:</span>
          <span><%= content.email %></span>
        </a>
        
        <span class="label"><%= content.region %></span>
      </div>
    </div>
  </div>
</header>

<main>
  <section class="hero<% if (content.heroImage) { %> has-hero-bg<% } %>" style="<% if (content.heroImage) { %>background-image: url('<%= content.heroImage %>'); background-size: cover; background-position: center;<% } else { %>background: var(--bg-light);<% } %>">
    <div class="container hero-inner">
      <div>
        <h1 class="hero-title"><%= content.heroTitle %></h1>
        <p class="hero-subtitle"><%= content.heroSubtitle %></p>

        <ul class="hero-list">
          <li>Проекты любой сложности — от маленьких двориков до участков у коттеджей</li>
          <li>Подбор растений под ваш климат, почву и бюджет</li>
          <li>Работаем аккуратно и в понятные сроки, без «растянутых» ремонтов</li>
        </ul>
        <div class="hero-actions">
          <a href="#contacts" class="btn-primary">Оставить заявку</a>
          <a href="#services" class="btn-outline">Посмотреть услуги</a>
        </div>
        <p class="hero-note">Бесплатная первичная консультация по телефону или мессенджеру.</p>
      </div>

      <div class="hero-image">
        <div class="hero-image-content">
          <div class="hero-image-title">Что вы получите:</div>
          <ul class="hero-image-list">
            <li>Цельный, продуманный дизайн участка</li>
            <li>Здоровый газон и растения с правильной посадкой</li>
            <li>Удобные дорожки, зоны отдыха и освещение</li>
            <li>Рекомендации по уходу, чтобы красота не пропала через сезон</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="services" style="background:<%= content.sectionBg || '#f8f9f5' %>;">
    <div class="container">
      <h2 class="section-title">Что мы делаем</h2>
      <p class="section-subtitle">Полный цикл работ по озеленению и благоустройству — можно заказать как комплекс, так и отдельные услуги.</p>

      <div class="services-slider">
        <button type="button" class="services-btn services-prev" onclick="event.preventDefault(); showService(currentService - 1)">&#10094;</button>
        <div class="services-wrapper" id="servicesWrapper">
          <div class="services-track">
            <% content.services.forEach(function(service) { %>
              <div class="services-slide">
                <div class="card" style="background:<%= content.cardBg || '#ffffff' %>;">
                  <h3><%= service.title %></h3>
                  <p><%= service.text %></p>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
        <button type="button" class="services-btn services-next" onclick="event.preventDefault(); showService(currentService + 1)">&#10095;</button>
      </div>
      <div class="services-dots" id="servicesDots"></div>
    </div>
  </section>

  <section class="section gallery-section" style="background:<%= content.sectionBg || '#f8f9f5' %>;">
    <div class="container">
      <h2 class="section-title">Примеры работ</h2>
      
      <% if (content.gallery && content.gallery.length > 0) { %>
      <div class="gallery-slider">
        <button class="gallery-btn gallery-prev" onclick="moveSlide(-1)">&#10094;</button>
        <div class="gallery-wrapper">
          <div class="gallery-track" id="galleryTrack">
            <% 
            const itemsPerSlide = 3;
            for (let i = 0; i < content.gallery.length; i += itemsPerSlide) { 
              const slideImages = content.gallery.slice(i, i + itemsPerSlide);
            %>
              <div class="gallery-slide">
                <div class="gallery-images-row">
                  <% slideImages.forEach(function(img, idx) { %>
                    <div class="gallery-image-item">
                      <img src="<%= img %>" alt="Пример работы <%= i + idx + 1 %>">
                    </div>
                  <% }); %>
                </div>
              </div>
            <% } %>
          </div>
        </div>
        <button class="gallery-btn gallery-next" onclick="moveSlide(1)">&#10095;</button>
      </div>
      <div class="container">
        <div class="gallery-dots" id="galleryDots"></div>
      <% } else { %>
        <p class="portfolio-note">Фотографии работ скоро появятся. Здесь можно разместить фотографии готовых объектов: до/после, отдельные элементы дизайна, посадки и газон.</p>
        <ul class="portfolio-list">
          <li>Благоустройство участка у частного дома — 8 соток</li>
          <li>Озеленение территории у таунхауса</li>
          <li>Комплексное обновление старого сада</li>
        </ul>
      <% } %>
    </div>
  </section>

  <section class="section gallery-section" style="background:<%= content.sectionBg || '#f8f9f5' %>;">
    <div class="container">
      <h2 class="section-title">Ориентировочные цены</h2>
      <p class="section-subtitle">Точная стоимость зависит от площади, исходного состояния участка и выбранных материалов. После осмотра и обсуждения делаем подробную смету.</p>
      <div class="pricing">
        <% if (content.prices && content.prices.length > 0) { %>
          <% content.prices.forEach(function(price) { %>
            <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
              <h3><%= price.title %></h3>
              <div class="price-range"><%= price.price %></div>
              <p class="price-desc"><%= price.desc %></p>
            </div>
          <% }); %>
        <% } else { %>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Ландшафтный проект</h3>
          <div class="price-range">от 3 000 ₽ за сотку</div>
          <p class="price-desc">План участка, подбор растений и материалов, схемы посадок.</p>
        </div>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Озеленение и посадки</h3>
          <div class="price-range">по индивидуальной смете</div>
          <p class="price-desc">Работа + посадочный материал. Возможны варианты под ваш бюджет.</p>
        </div>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Газон под ключ</h3>
          <div class="price-range">от 350 ₽/м²</div>
          <p class="price-desc">Подготовка, выравнивание, укладка рулонного газона или посев.</p>
        </div>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Сезонный уход</h3>
          <div class="price-range">от 5 000 ₽ за выезд</div>
          <p class="price-desc">Обрезка, подкормки, обработка, подготовка к зиме.</p>
        </div>
        <% } %>
      </div>
    </div>
  </section>

  <section class="section gallery-section" style="background:<%= content.sectionBg || '#f8f9f5' %>;">
    <div class="container">
      <h2 class="section-title">Почему с нами удобно</h2>
      <div class="pricing">
        <% if (content.prices2 && content.prices2.length > 0) { %>
          <% content.prices2.forEach(function(price, index) { %>
            <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>; display:flex !important; align-items:flex-start !important; gap:10px !important; font-size:14px !important; margin-bottom:16px !important; color:#000 !important;">
              <div style="flex-shrink:0 !important; width:26px !important; height:26px !important; border-radius:999px !important; background-color:#f5f7f4 !important; display:flex !important; align-items:center !important; justify-content:center !important; font-size:13px !important; color:#285428 !important; font-weight:600 !important; border:1px solid #285428 !important;"><%= index + 1 %></div>
              <div>
                <h3><%= price.title %></h3>
                <div class="price-range"><%= price.price %></div>
                <p class="price-desc"><%= price.desc %></p>
              </div>
            </div>
          <% }); %>
        <% } else { %>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Ландшафтный проект</h3>
          <div class="price-range">от 3 000 ₽ за сотку</div>
          <p class="price-desc">План участка, подбор растений и материалов, схемы посадок.</p>
        </div>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Озеленение и посадки</h3>
          <div class="price-range">по индивидуальной смете</div>
          <p class="price-desc">Работа + посадочный материал. Возможны варианты под ваш бюджет.</p>
        </div>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Газон под ключ</h3>
          <div class="price-range">от 350 ₽/м²</div>
          <p class="price-desc">Подготовка, выравнивание, укладка рулонного газона или посев.</p>
        </div>
        <div class="price-item" style="background:<%= content.cardBg || '#ffffff' %>;">
          <h3>Сезонный уход</h3>
          <div class="price-range">от 5 000 ₽ за выезд</div>
          <p class="price-desc">Обрезка, подкормки, обработка, подготовка к зиме.</p>
        </div>
        <% } %>
      </div>
    </div>
  </section>

  <section class="section gallery-section" id="contacts">
    <div class="container contacts-grid" style="background:<%= content.cardBg || '#ffffff' %>;">
      <div class="contact-info" style="color:<%= content.formText || '#222222' %>;">
        <h2 class="section-title">Связаться с нами</h2>
        <p>Расскажите кратко о вашем участке и задаче — мы предложим варианты решения и сориентируем по срокам и бюджету.</p>
        <p><strong>Телефон:</strong> <a href="tel:+<%= content.phone.replace(/[^0-9]/g, '') %>"><%= content.phone %></a></p>
        <p><strong>Почта:</strong> <a href="mailto:<%= content.email %>"><%= content.email %></a></p>
        <p><strong>Регион:</strong> <%= content.region %></p>
        <p><strong>График работы:</strong> ежедневно, 9:00–20:00</p>
      </div>
      <div class="contact-form" style="background:<%= content.formBg || '#ffffff' %>; color:<%= content.formText || '#222222' %>;">
        <form id="contactForm">
          <label for="name">Имя</label>
          <input id="name" type="text" name="name" placeholder="Как к вам обращаться" required>
          <label for="phone">Телефон</label>
          <input id="phone" type="tel" name="phone" placeholder="+7 (___) ___‑__‑__" required>
          <label for="message">Кратко опишите задачу</label>
          <textarea id="message" name="message" placeholder="Площадь участка, что хотите сделать, удобное время для звонка"></textarea>
          <div class="consent-wrapper">
            <input type="checkbox" id="consent" name="consent" required>
            <label for="consent">Даю согласие на обработку <a href="/privacy-policy" target="_blank">персональных данных</a></label>
          </div>
          <button type="submit" class="btn-primary" style="width:100%;margin-top:4px;">Отправить заявку</button>
        </form>
        <div id="formMessage" style="display:none;margin-top:10px;padding:10px;border-radius:4px;"></div>
      </div>
      <script>
        document.getElementById('contactForm').addEventListener('submit', async (e) => {
          e.preventDefault();
          const formData = new FormData(e.target);
          const data = Object.fromEntries(formData);
          const btn = e.target.querySelector('button');
          btn.disabled = true;
          btn.textContent = 'Отправка...';
          try {
            const res = await fetch('/api/contact', {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify(data)
            });
            const result = await res.json();
            const msg = document.getElementById('formMessage');
            msg.style.display = 'block';
            if (result.success) {
              msg.style.background = '#d4edda';
              msg.style.color = '#155724';
              msg.textContent = 'Спасибо! Заявка отправлена. Мы свяжемся с вами.';
              e.target.reset();
            } else {
              msg.style.background = '#f8d7da';
              msg.style.color = '#721c24';
              msg.textContent = 'Ошибка. Попробуйте позвонить нам.';
            }
          } catch(err) {
            msg.textContent = 'Ошибка отправки';
          }
          btn.disabled = false;
          btn.textContent = 'Отправить заявку';
        });
      </script>
    </div>
  </section>
</main>

<footer style="background:<%= content.footerBg || '#1b361b' %>; color:<%= content.footerText || '#ffffff' %>;">
  <div class="container footer-inner">
    <div>© <span id="year"></span> Территория Флоры. Озеленение и ландшафтный дизайн.</div>
    <div><%= content.region %></div>
    <div><a href="/privacy-policy" style="color:<%= content.footerText || '#ffffff' %>;">Политика конфиденциальности</a></div>
    <div>Разработка сайта: Гречков Борис</div>
  </div>
</footer>
<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Header scroll effect
  let lastScroll = 0;
  
  function hexToRgba(hex, alpha) {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }
  
  window.addEventListener('scroll', function() {
    const header = document.querySelector('#mainHeader');
    const servicesSection = document.getElementById('services');
    const headerBg = header.dataset.headerBg || '#264d26';
    const headerBgScrolled = header.dataset.headerBgScrolled || headerBg;
    const titleColor = header.dataset.titleColor || '#ffffff';
    const titleColorScrolled = header.dataset.titleColorScrolled || '#222222';
    if (header.classList.contains('transparent') && servicesSection) {
      const rect = servicesSection.getBoundingClientRect();
      if (rect.top <= 100) {
        header.style.background = hexToRgba(headerBgScrolled, 0.8);
        document.querySelector('.site-title').style.color = titleColorScrolled;
        document.querySelectorAll('.header-contacts, .header-contacts a, .header-contacts .label').forEach(el => el.style.color = titleColorScrolled);
      } else {
        header.style.background = hexToRgba(headerBg, 0.5);
        document.querySelector('.site-title').style.color = titleColor;
        document.querySelectorAll('.header-contacts, .header-contacts a, .header-contacts .label').forEach(el => el.style.color = '');
      }
    }
    lastScroll = window.scrollY;
  });
  
  // Init header on page load
  (function() {
    const header = document.querySelector('#mainHeader');
    const headerBg = header.dataset.headerBg || '#264d26';
    if (header.classList.contains('transparent')) {
      header.style.background = hexToRgba(headerBg, 0.5);
    }
  })();
  
  let currentSlide = 0;
  const track = document.getElementById('galleryTrack');
  const dotsContainer = document.getElementById('galleryDots');
  const itemsPerSlide = 3;
  
  function showSlide(index) {
    const slides = document.querySelectorAll('.gallery-slide');
    if (!slides.length) return;
    
    if (index >= slides.length) currentSlide = 0;
    else if (index < 0) currentSlide = slides.length - 1;
    else currentSlide = index;
    
    track.style.transform = `translateX(-${currentSlide * 100}%)`;
    
    // Update dots
    const dots = dotsContainer.querySelectorAll('span');
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentSlide);
    });
  }
  
  function moveSlide(direction) {
    showSlide(currentSlide + direction);
  }
  
  // Create dots
  function initGallery() {
    const slides = document.querySelectorAll('.gallery-slide');
    if (!slides.length || !dotsContainer) return;
    
    slides.forEach((_, i) => {
      const dot = document.createElement('span');
      dot.onclick = () => showSlide(i);
      dotsContainer.appendChild(dot);
    });
    showSlide(0);
    
    // Auto-scroll every 5 seconds
    setInterval(() => {
      if (slides.length > 1) {
        showSlide(currentSlide + 1);
      }
    }, 5000);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }

  // Services slider
  let currentService = 0;
  const servicesWrapper = document.getElementById('servicesWrapper');
  const servicesDotsContainer = document.getElementById('servicesDots');
  
  function showService(index) {
    const slides = document.querySelectorAll('.services-slide');
    const track = document.querySelector('.services-track');
    if (!slides.length || !track) return;
    
    const totalSlides = slides.length;
    if (index >= totalSlides) currentService = 0;
    else if (index < 0) currentService = totalSlides - 1;
    else currentService = index;
    
    const slideWidth = slides[0].offsetWidth + 18; // width + gap
    track.style.transform = `translateX(-${currentService * slideWidth}px)`;
    
    // Update dots
    const dots = servicesDotsContainer.querySelectorAll('span');
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentService);
    });
  }
  
  // Init services dots
  function initServices() {
    const slides = document.querySelectorAll('.services-slide');
    if (!slides.length || !servicesDotsContainer) return;
    
    slides.forEach((_, i) => {
      const dot = document.createElement('span');
      dot.onclick = (e) => { e.preventDefault(); showService(i); };
      servicesDotsContainer.appendChild(dot);
    });
    
    // Touch swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    
    servicesWrapper.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    
    servicesWrapper.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) moveService(1);
        else moveService(-1);
      }
    }, { passive: true });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServices);
  } else {
    initServices();
  }
</script>

